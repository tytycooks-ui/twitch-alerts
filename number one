<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Orbitron:wght@700;900&display=swap');

  *{margin:0;padding:0;box-sizing:border-box;}

  body{
    background:transparent;
    width:600px;
    height:200px;
    overflow:hidden;
    font-family:'Rajdhani',sans-serif;
  }

  /* ── ALERT BOX ── */
  #alert-box{
    position:absolute;
    top:20px;left:0;
    width:560px;
    padding:18px 24px 18px 80px;
    border-radius:6px;
    background:linear-gradient(135deg,#0a1628 0%,#0d2150 60%,#0a1628 100%);
    border:1px solid #1e3a6e;
    box-shadow:
      0 0 0 1px #002A7F55,
      0 0 20px #002A7F88,
      0 0 50px #002A7F44,
      inset 0 0 30px #00000066;
    display:none;
    flex-direction:column;
    gap:4px;
    overflow:hidden;
  }

  #alert-box::before{
    content:'';
    position:absolute;
    top:0;left:0;right:0;
    height:3px;
    background:linear-gradient(90deg,transparent,#4a90d9,#C0C0C0,#4a90d9,transparent);
  }

  .alert-icon{
    position:absolute;
    left:0;top:0;bottom:0;
    width:60px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:1.7rem;
    background:linear-gradient(180deg,#002A7F,#001a50);
    border-right:1px solid #4a90d955;
  }

  .star-bg{
    position:absolute;
    right:18px;top:50%;
    transform:translateY(-50%);
    font-size:2.4rem;
    opacity:.1;
    color:#C0C0C0;
    pointer-events:none;
  }

  .alert-type{
    font-family:'Orbitron',sans-serif;
    font-size:.6rem;
    letter-spacing:3px;
    text-transform:uppercase;
    color:#4a90d9;
  }

  .alert-headline{
    font-family:'Orbitron',sans-serif;
    font-size:1.1rem;
    color:#e8e8f0;
    text-shadow:0 0 12px #4a90d9cc;
    line-height:1.3;
  }

  .alert-headline span{color:#C0C0C0;text-shadow:0 0 14px #ffffffaa;}

  .alert-sub{
    font-size:.9rem;
    color:#8aabcf;
    letter-spacing:.5px;
  }

  .amount-badge{
    display:inline-block;
    background:linear-gradient(135deg,#002A7F,#4a90d9);
    color:#fff;
    font-family:'Orbitron',sans-serif;
    font-size:.8rem;
    padding:2px 10px;
    border-radius:20px;
    margin-top:2px;
    box-shadow:0 0 10px #4a90d966;
  }

  .streak{
    display:inline-flex;
    align-items:center;
    gap:4px;
    background:#001a5066;
    border:1px solid #4a90d944;
    border-radius:4px;
    padding:2px 8px;
    font-size:.75rem;
    color:#4a90d9;
    margin-top:2px;
  }

  .raid-count{
    font-family:'Orbitron',sans-serif;
    font-size:1.6rem;
    color:#4a90d9;
    text-shadow:0 0 18px #4a90d9;
    line-height:1;
  }
  .raid-count small{
    font-size:.5rem;
    letter-spacing:3px;
    color:#8aabcf;
    display:block;
  }

  .progress-wrap{
    margin-top:6px;
    height:4px;
    border-radius:2px;
    background:#0a1628;
    overflow:hidden;
    width:100%;
  }
  .progress-bar{
    height:100%;
    border-radius:2px;
    background:linear-gradient(90deg,#002A7F,#4a90d9,#C0C0C0);
    width:0%;
    transition:width 1.2s ease-out;
  }

  /* ── ANIMATIONS ── */
  @keyframes slideIn{
    from{opacity:0;transform:translateX(-80px);}
    to{opacity:1;transform:translateX(0);}
  }
  @keyframes slideOut{
    from{opacity:1;transform:translateX(0);}
    to{opacity:0;transform:translateX(80px);}
  }
  @keyframes pulse{
    0%,100%{box-shadow:0 0 0 1px #002A7F55,0 0 20px #002A7F88,0 0 50px #002A7F44,inset 0 0 30px #00000066;}
    50%{box-shadow:0 0 0 1px #4a90d9aa,0 0 30px #4a90d9aa,0 0 70px #002A7F66,inset 0 0 30px #00000066;}
  }

  .show{
    display:flex !important;
    animation:slideIn .6s cubic-bezier(.16,1,.3,1) forwards, pulse 2s 1s ease-in-out infinite;
  }
  .hide{
    animation:slideOut .5s ease-in forwards !important;
  }
</style>
</head>
<body>

<div id="alert-box">
  <div class="alert-icon" id="alert-icon">⭐</div>
  <div class="star-bg">⭐</div>
  <div class="alert-type" id="alert-type">EVENT</div>
  <div class="alert-headline" id="alert-headline"></div>
  <div id="alert-extra"></div>
</div>

<script>
// ─────────────────────────────────────────────
//  StreamElements Event Listener
// ─────────────────────────────────────────────
var box      = document.getElementById('alert-box');
var iconEl   = document.getElementById('alert-icon');
var typeEl   = document.getElementById('alert-type');
var headEl   = document.getElementById('alert-headline');
var extraEl  = document.getElementById('alert-extra');

var queue    = [];
var playing  = false;

// ── Receive SE events ──
window.addEventListener('onEventReceived', function(e){
  var d = e.detail;
  var type = d.listener;
  var data = d.event;

  var cfg = null;

  if(type === 'follower-latest'){
    cfg = {
      icon:'👁️',
      label:'New Follower',
      headline:`<span>${data.name}</span> just followed!`,
      extra:`<div class="alert-sub">Welcome to the squad — How 'Bout Them Cowboys! 🏈</div>`
    };
  }
  else if(type === 'subscriber-latest'){
    var months = data.amount > 1 ? `<div class="streak">🔥 ${data.amount}-Month Streak</div>` : '';
    var tier = data.tier === '2000' ? 'Tier 2' : data.tier === '3000' ? 'Tier 3' : 'Tier 1';
    cfg = {
      icon: data.amount > 1 ? '🔁' : '🌟',
      label: data.amount > 1 ? 'Resubscribe' : 'New Subscriber',
      headline:`<span>${data.name}</span> ${data.amount > 1 ? 'resubscribed!' : 'just subscribed!'}`,
      extra:`<div class="alert-sub">${tier} • ${data.amount > 1 ? 'Keeping the streak alive!' : 'Thanks for the support!'}</div>
             ${months}
             <div class="progress-wrap"><div class="progress-bar" id="pbar"></div></div>`
    };
  }
  else if(type === 'tip-latest'){
    var msg = data.message ? `<div class="alert-sub" style="margin-top:4px">"${data.message}"</div>` : '';
    cfg = {
      icon:'💰',
      label:'Donation',
      headline:`<span>${data.username}</span> donated!`,
      extra:`<div class="amount-badge">$${parseFloat(data.amount).toFixed(2)}</div>${msg}`
    };
  }
  else if(type === 'cheer-latest'){
    cfg = {
      icon:'💎',
      label:'Cheer / Bits',
      headline:`<span>${data.name}</span> cheered!`,
      extra:`<div class="alert-sub">${data.amount} Bits — Let's go Cowboys! 🏈</div>`
    };
  }
  else if(type === 'raid-latest'){
    cfg = {
      icon:'⚔️',
      label:'Incoming Raid',
      headline:`<span>${data.name}</span> is raiding!`,
      extra:`<div style="display:flex;align-items:flex-end;gap:10px;margin-top:4px;">
               <div class="raid-count">${data.amount}<small>raiders incoming</small></div>
               <div class="alert-sub">Welcome the squad! 🏟️</div>
             </div>`
    };
  }
  else if(type === 'host-latest'){
    cfg = {
      icon:'📡',
      label:'Host',
      headline:`<span>${data.name}</span> is hosting!`,
      extra:`<div class="alert-sub">📺 Hosting with ${data.amount} viewers</div>`
    };
  }

  if(cfg){ queue.push(cfg); if(!playing) playNext(); }
});

// ── Queue system ──
function playNext(){
  if(queue.length === 0){ playing=false; return; }
  playing = true;
  var cfg = queue.shift();

  iconEl.textContent  = cfg.icon;
  typeEl.textContent  = cfg.label;
  headEl.innerHTML    = cfg.headline;
  extraEl.innerHTML   = cfg.extra;

  box.classList.remove('hide');
  box.classList.add('show');

  // animate progress bar if present
  var pb = document.getElementById('pbar');
  if(pb){ setTimeout(()=>{ pb.style.width='65%'; },200); }

  // hide after 6 seconds
  setTimeout(function(){
    box.classList.add('hide');
    setTimeout(function(){
      box.classList.remove('show','hide');
      box.style.display='none';
      playNext();
    }, 600);
  }, 6000);
}

// ─────────────────────────────────────────────
//  DEMO MODE  (fires when opened in browser)
// ─────────────────────────────────────────────
var demos = [
  { listener:'follower-latest',    event:{ name:'CowboysNation88' } },
  { listener:'subscriber-latest',  event:{ name:'DallasDiehard', amount:1, tier:'1000' } },
  { listener:'subscriber-latest',  event:{ name:'BlueStarFan', amount:6, tier:'1000' } },
  { listener:'tip-latest',         event:{ username:'TipKing_TX', amount:'10.00', message:'Dak would be proud 🤙' } },
  { listener:'cheer-latest',       event:{ name:'BitSlinger', amount:500 } },
  { listener:'raid-latest',        event:{ name:'StreamLegend', amount:247 } },
  { listener:'host-latest',        event:{ name:'NightOwlGamer', amount:89 } },
];

var di = 0;
function fireDemo(){
  if(di >= demos.length) return;
  window.dispatchEvent(new CustomEvent('onEventReceived',{ detail: demos[di++] }));
  if(di < demos.length) setTimeout(fireDemo, 7200);
}
setTimeout(fireDemo, 800);
</script>
</body>
</html>
